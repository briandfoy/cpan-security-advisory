#!/Users/brian/bin/perl
use v5.34;
use utf8;
use open qw(:std :utf8);

use FindBin qw($Bin);
use lib "$Bin/../lib";

use Mojo::Util qw(dumper);
use Term::ANSIColor;
use Local::CPANSA qw(:cve);

=encoding utf8

=head1 NAME

list_cves - show all the CVEs that mention "perl"

=head1 SYNOPSIS

	% perl util/list_cves

=head1 DESCRIPTION



=cut

my %Count;
foreach my $v ( get_all_cve()->@* ) {
	my $cve  = $v->{cve};
	my( $mark, $color ) = do {
		   if( $v->{'recorded'} ) { ( '✔', 'bold green' ) }
		elsif( $v->{'ignored'}  ) { ('*',  'red'        ) }
		else                      { ( '?', 'bold cyan'  ) }
		};
	$Count{$mark}++;
	print colored(
		[ $color ],
		sprintf "%s  %-17s %s\n", $mark, $cve, $v->{'description'}
		);
	}

say "\nSummary\n-------";
foreach my $mark ( keys %Count ) {
	say "$mark: $Count{$mark}";
	}
