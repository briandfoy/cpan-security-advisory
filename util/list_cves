__PACKAGE__;

my %Count;
foreach my $v ( get_all_cve()->@* ) {
	my $cve  = $v->{cve};
	my( $mark, $color ) = do {
		   if( $v->{'recorded'} ) { ( '✔', 'bold green' ) }
		elsif( $v->{'ignored'}  ) { ('*',  'red'        ) }
		else                      { ( '?', 'bold cyan'  ) }
		};
	$Count{$mark}++;
	print colored(
		[ $color ],
		sprintf "%s  %-17s %s\n", $mark, $cve, substr( $v->{'description'}, 0, 72 )
		);
	}

say "\nSummary\n-------";
foreach my $mark ( keys %Count ) {
	say "$mark: $Count{$mark}";
	}

exit( !! $Count{'?'} );

